{
  "name": "@feelingmindful/ynab-mcp-server",
  "version": "0.1.2",
  "description": "ynab-mcp-server MCP server",
  "author": "Nick Prokesch <nick@prokes.ch>",
  "type": "module",
  "bin": {
    "ynab-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/calebl/ynab-mcp-server.git"
  },
  "scripts": {
    "build": "next build",
    "build:cli": "tsc -p tsconfig.cli.json && node -e \"const fs=require('node:fs');if(fs.existsSync('dist/index.js'))fs.chmodSync('dist/index.js',0o755)\"",
    "prepare": "npm run build:cli",
    "watch": "tsc -p tsconfig.cli.json --watch",
    "start": "node dist/index.js",
    "debug": "npm run build:cli && npx @modelcontextprotocol/inspector dist/index.js",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "dev": "next dev",
    "next:start": "next start"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/axios": "^0.14.4",
    "axios": "^1.8.4",
    "commander": "^14.0.1",
    "mcp-handler": "^1.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ynab": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.16.5",
    "@types/node": "^20.11.24",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  }
}
